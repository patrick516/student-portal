generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Core School Entities ----------
model School {
  id           String        @id @default(uuid())
  name         String
  createdAt    DateTime      @default(now())
  users        User[]
  classes      Class[]
  students     Student[]
  subjects     Subject[]
  invoices     Invoice[]
  payments     Payment[]
  attendance   Attendance[]
  assessments  Assessment[]
  marks        Mark[]
  gradeSchemes GradeScheme[]
  guardians    Guardian[]
  terms        Term[]
  feeSettings  FeeSetting[]
}

model Term {
  id        String   @id @default(uuid())
  schoolId  String
  name      String // e.g. "Term 1", "Term 2"
  year      Int // e.g. 2025
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(false)

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name, year])
  @@index([schoolId, year, name])
}

// ---------- Classes ----------
model Class {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  stream    String?
  year      Int?
  createdAt DateTime @default(now())

  school        School    @relation(fields: [schoolId], references: [id])
  students      Student[]
  formTeacherId String?
  formTeacher   User?     @relation("FormTeacher", fields: [formTeacherId], references: [id])

  teacherClasses     TeacherClass[]
  teacherAssignments TeacherAssignment[]
  attendance         Attendance[]
  assessments        Assessment[]
  marks              Mark[]
  gradeScheme        GradeScheme?

  @@index([schoolId, name, stream])
}

model FeeSetting {
  id        String   @id @default(uuid())
  schoolId  String
  termId    String
  classId   String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school School @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, termId, classId])
  @@index([schoolId, termId, classId])
}

// ---------- Users ----------
model User {
  id                 String   @id @default(uuid())
  schoolId           String
  email              String   @unique
  name               String
  role               String // admin | teacher | bursar | viewer
  passwordHash       String
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(true)
  createdAt          DateTime @default(now())

  staffCode       String?   @unique
  phone           String?
  employmentStart DateTime?

  school         School              @relation(fields: [schoolId], references: [id])
  teacherClasses TeacherClass[]
  assignments    TeacherAssignment[]
  formClasses    Class[]             @relation("FormTeacher")

  @@index([schoolId, role])
}

// ---------- Subjects ----------
model Subject {
  id        String   @id @default(uuid())
  schoolId  String
  name      String
  code      String?  @unique
  createdAt DateTime @default(now())

  school      School              @relation(fields: [schoolId], references: [id])
  assignments TeacherAssignment[]
  assessments Assessment[]
  marks       Mark[]

  @@unique([schoolId, name])
  @@index([schoolId, name])
}

// ---------- Students ----------
model Student {
  id          String   @id @default(uuid())
  schoolId    String
  studentCode String
  firstName   String
  lastName    String
  status      String   @default("active")
  createdAt   DateTime @default(now())

  currentClassId String?
  currentClass   Class?  @relation(fields: [currentClassId], references: [id])
  school         School  @relation(fields: [schoolId], references: [id])

  invoices   Invoice[]
  payments   Payment[]
  attendance Attendance[]
  marks      Mark[]
  guardians  Guardian[]

  @@unique([schoolId, studentCode])
  @@index([schoolId, currentClassId])
  @@index([schoolId, lastName, firstName])
}

model Guardian {
  id        String   @id @default(uuid())
  schoolId  String
  studentId String
  name      String
  email     String?
  phone     String?
  relation  String?
  createdAt DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@index([schoolId, studentId])
}

// ---------- Teacher Allocations ----------
model TeacherClass {
  id        String   @id @default(uuid())
  teacherId String
  classId   String
  createdAt DateTime @default(now())

  teacher User  @relation(fields: [teacherId], references: [id])
  klass   Class @relation(fields: [classId], references: [id])

  @@unique([teacherId, classId])
  @@index([classId])
  @@index([teacherId])
}

model TeacherAssignment {
  id        String   @id @default(uuid())
  teacherId String
  classId   String
  subjectId String
  createdAt DateTime @default(now())

  teacher User    @relation(fields: [teacherId], references: [id])
  klass   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])

  @@unique([teacherId, classId, subjectId])
  @@index([teacherId])
  @@index([classId])
  @@index([subjectId])
}

// ---------- Attendance ----------
model Attendance {
  id        String   @id @default(uuid())
  schoolId  String
  studentId String
  classId   String
  date      DateTime
  status    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school  School  @relation(fields: [schoolId], references: [id])
  student Student @relation(fields: [studentId], references: [id])
  klass   Class   @relation(fields: [classId], references: [id])

  @@unique([studentId, date])
  @@index([schoolId, classId, date])
}

// ---------- Fees ----------
model Invoice {
  id        String   @id @default(uuid())
  schoolId  String
  studentId String
  termId    String? // stores Term.id
  amount    Decimal  @db.Decimal(12, 2)
  status    String   @default("unpaid") // 'unpaid' | 'partial' | 'paid'
  issuedAt  DateTime @default(now())

  school   School    @relation(fields: [schoolId], references: [id])
  student  Student   @relation(fields: [studentId], references: [id])
  payments Payment[]

  @@index([schoolId, studentId])
  @@index([schoolId, status])
  @@index([schoolId, termId])
}

model Payment {
  id         String   @id @default(uuid())
  schoolId   String
  invoiceId  String
  studentId  String
  amount     Decimal  @db.Decimal(12, 2)
  method     String?
  reference  String?
  paidAt     DateTime @default(now())
  recordedBy String?

  school  School  @relation(fields: [schoolId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])
  student Student @relation(fields: [studentId], references: [id])

  @@index([schoolId, studentId])
  @@index([invoiceId])
}

// ---------- Exams / Scores ----------
model Assessment {
  id        String   @id @default(uuid())
  schoolId  String
  classId   String
  subjectId String
  name      String
  weight    Int
  optional  Boolean  @default(true)
  createdBy String
  createdAt DateTime @default(now())

  school  School  @relation(fields: [schoolId], references: [id])
  klass   Class   @relation(fields: [classId], references: [id])
  subject Subject @relation(fields: [subjectId], references: [id])
  marks   Mark[]

  @@index([schoolId, classId, subjectId])
}

model Mark {
  id           String   @id @default(uuid())
  schoolId     String
  classId      String
  subjectId    String
  studentId    String
  teacherId    String
  assessmentId String
  score        Decimal  @db.Decimal(6, 2)
  markedAt     DateTime @default(now())

  school     School     @relation(fields: [schoolId], references: [id])
  klass      Class      @relation(fields: [classId], references: [id])
  subject    Subject    @relation(fields: [subjectId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  assessment Assessment @relation(fields: [assessmentId], references: [id])

  @@unique([studentId, assessmentId])
  @@index([schoolId, classId, subjectId])
}

// ---------- Grade Scheme ----------
model GradeScheme {
  id        String   @id @default(uuid())
  schoolId  String
  classId   String
  createdBy String
  createdAt DateTime @default(now())
  bands     Json

  school School @relation(fields: [schoolId], references: [id])
  klass  Class  @relation(fields: [classId], references: [id])

  @@unique([classId])
  @@index([schoolId, classId])
}
